<?xml version="1.0" encoding="UTF-8"?>
<frames xmlns="http://www.w3.org/2002/06/xframes/">
	<head>
		
		<title>Home page</title>
		<style type="text/css">
         #banner {height: 10em }
         #atoz, #nav {width: 20%}
         #footer {height: 4em }
      </style>
	</head>
	<group compose="vertical">
		<frame xml:id="banner" source="xml/xhtml/v2/banner.xhtml"/>
		<group compose="horizontal">
			<frame xml:id="atoz" source="atoz.xhtml"/>
			<frame xml:id="main" source="news.xhtml"/>
			<frame xml:id="nav" source="nav.xhtml"/>
		</group>
		<frame xml:id="footer" source="xml/xhtml/v2/footer.xhtml"/>
	</group>
</frames>