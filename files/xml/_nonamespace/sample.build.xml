<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE project [
<!ENTITY maven SYSTEM "https://raw.githubusercontent.com/nandaka-furari/files/master/ent/ant/property/selection-maven_directory.ent">
]>
<project name="entity" xmlns:ivy="antlib:org.apache.ivy.ant">
    <property name="" value=""></property>
    &maven;
    <target name="resolve" description="--> retreive dependencies with ivy">
        <ivy:retrieve/>
    </target>
    <target name="create-dir">
        <mkdir dir="${java.src}"/>
    </target>

    <path id="lib.path.id">
        <fileset dir="${lib.dir}"/>
    </path>
    <path id="run.path.id">
        <path refid="lib.path.id"/>
        <path location="${build.dir}"/>
    </path>

    <!-- maven-compiler -->
    <target name="clean">
        <delete>
            <fileset dir="${classes}"></fileset>

        </delete>
    </target>
    <target name="compile" depends="resolve">
        <javac srcdir="${java.src}">
            <classpath></classpath>
        </javac>
    </target>
    <target name="test" depends="compile">
    </target>
    <target name="package" depends="test">
    </target>
    <target name="install">
    </target>
    <!-- maven-compiler -->

    <target name="build-static-files" description="静的ファイルを生成する">
        <exec command="">
            <arg/>
        </exec>
    </target>
    <property environment="env"/>
    <property name="encoding" value="UTF-8"/>
    <property name="source" value="ignore"/>
    <property name="container.dir" value="build/container"/>
    <property name="saxon" value="C:/opt/SaxonHE9-6-0-6J/saxon9he.jar"></property>

    <condition property="mvn" value="mvn.bat" else="mvn">
        <os family="windows"/>
    </condition>
    <!-- ================================= target: build ================================= -->
    <target name="build" description="デフォルトのビルド">
        <echo message="path:${env.Path}"/>

        <echo message="${mvn}"/>
    </target>

    <target name="build.container.xs">
        <echo>xsd</echo>
        <mkdir dir="${container.dir}"/>
        <delete dir="${container.dir}/*"/>

        <mkdir dir="${container.dir}/src/main/java"/>
        <exec executable="xjc">
            <arg value="-d"/>
            <arg path="${container.dir}/src/main/java"/>
            <arg value="-encoding"/>
            <arg value="${encoding}"/>
            <arg value="resources/schema/xs/container3/container_3_0.xsd"/>
        </exec>

        <copy file="ignore/container/pom.xml" todir="build/container"/>

        <exec executable="${mvn}">
            <arg line="-f"/>
            <arg value="${container.dir}"/>
            <arg value="compile"/>
            <arg value="package"/>
            <arg value="install"/>
        </exec>
    </target>
    
    <!--
    --- xhtml ---
    -->
    <target name="build-xhtml">
        <xslt style=""/>

        <xslt style="xhtmlproducer.xslt" destdir="target/site" basedir="src/site/xml/xhtml/v2" includes="source/template"
              extension=".xhtml" filenameparameter="filename" filedirparameter="filedir"/>

    </target>
    <!-- ================================= target: echoxslt ================================= -->
    <target name="echoxslt" description="description">
        <delete>
            <fileset dir="product/xhtml">
                <include name="**"/>
            </fileset>
        </delete>

        <fileset dir="dir" id="id">
            <include name="include"/>
            <exclude name="exclude"/>
        </fileset>

        <echo>${basedir}</echo>
        <xslt style="echo.xslt"
              classpath="${saxon}"
              destdir="product/xhtml"
              basedir="source"
              includes="contents/index.xhtml"
              excludes="excludes/**"
              extension=".xhtml">

            <param name="sourceDir" expression="${basedir}/source"/>
        </xslt>

    </target>


</project>