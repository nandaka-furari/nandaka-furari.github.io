<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ivysettings [
<!ENTITY ibilio SYSTEM "https://raw.githubusercontent.com/nandaka-furari/files/master/ent/ivysettings/resolvers/ibiblio.ent">
]>
<ivysettings>
    <properties file="${ivy.settings.dir}/ivysettings-file.properties" />
    <settings defaultResolver="mavencentral"/>
    <resolvers>
        <caches  defaultCacheDir="${cache.dir}" checkUpToDate="false" />
    	&ibilio;
    	<filesystem name="internal">
    		<ivy pattern="${repository.dir}/[module]/ivy-[revision].xml" />
    		<artifact pattern="${repository.dir}/[module]/[artifact]-[revision].[ext]" />
    	</filesystem>
    	<chain name="default" returnFirst="true">
            <resolver ref="mavencentral"/>
            <resolver ref="jboss"/>
        </chain>
    </resolvers>
        <modules>
                <module organisation="jayasoft" name=".*" resolver="internal" />
        </modules>
</ivysettings>