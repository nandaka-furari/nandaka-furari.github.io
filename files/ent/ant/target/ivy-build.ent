<?xml version="1.0" encoding="UTF-8"?>
    <target name="resolve" description="--> retreive dependencies with ivy">
        <ivy:retrieve/>
    </target>
    <target name="create-dir">
    	<mkdir dir="${java.src}"/>
    </target>

    <path id="lib.path.id">
        <fileset dir="${lib.dir}" />
	</path>
    <path id="run.path.id">
        <path refid="lib.path.id" />
        <path location="${build.dir}" />
    </path>

    <!-- maven-compiler -->
    <target name="clean">
    	<delete>
    		<fileset dir="${classes}"></fileset>
    		
    	</delete>
    </target>
	<target name="compile" depends="resolve">
		<javac srcdir="${java.src}" >
			<classpath></classpath>
		</javac>
	</target>
	<target name="test" depends="compile">
	</target>
	<target name="package" depends="test">
	</target>
	<target name="install">
	</target>
    <!-- maven-compiler -->

	<target name="script">
    	<exec command="">
    		<arg />
    	</exec>
    </target>