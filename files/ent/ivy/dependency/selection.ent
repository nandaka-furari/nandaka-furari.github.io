<dependency org="org.apache.commons" name="commons-pool2" rev="latest.integration" conf="compile"/>

<dependency org="com.google.guava" name="guava" rev="latest.integration" conf="compile"/>

<dependency org="org.codehaus.groovy" name="groovy-all" rev="latest.integration" conf="compile"/>
<dependency org="org.scala-lang" name="scala-library" rev="latest.integration" conf="compile"/>

