<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
	<Document>
		<name>ノヤブリスク計画</name>
		<description>木と砂の路</description>
		<!-- Point -->
		<!-- メイン -->
		<Style id="メインポイントnormal">
			<IconStyle>
				<color>ff0000ff</color>
				<scale>3.5</scale>
				<Icon>
					<href>http://maps.google.com/mapfiles/kml/shapes/square.png</href>
				</Icon>
			</IconStyle>
			<LabelStyle>
				<scale>3</scale>
			</LabelStyle>
		</Style>
		<Style id="メインポイントhighlight">
