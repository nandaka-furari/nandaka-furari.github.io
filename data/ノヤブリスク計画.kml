			<description>中心</description>
			<styleUrl>#メインポイント</styleUrl>
			<Point>
				<altitudeMode>relativeToGround</altitudeMode>
				<coordinates>75.447760,63.184196,0</coordinates>
			</Point>
		</Placemark>
		<Placemark>
			<name>タハト</name>
