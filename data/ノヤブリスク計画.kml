				<color>ff0000ff</color>
				<scale>3</scale>
				<Icon>
					<href>http://maps.google.com/mapfiles/kml/shapes/square.png</href>
				</Icon>
			</IconStyle>
			<LabelStyle>
				<scale>3</scale>
			</LabelStyle>
		</Style>
		<StyleMap id="メインポイント">
